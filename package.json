    "uuid": "^11.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/dxt": "^0.2.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
