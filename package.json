  },
  "files": [
    "dist"
  ],
  "type": "module",
  "bin": {
    "agentlink": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
