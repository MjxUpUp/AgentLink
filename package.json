{
  "name": "@agentlink/server",
  "version": "0.1.0",
  "description": "P2P communication layer for AI programming agents",
  "keywords": [
    "mcp",
    "agent",
    "p2p",
    "ai",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
